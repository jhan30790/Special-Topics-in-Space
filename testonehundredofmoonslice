clear;clc;close all;

projectPath='C:\Users\jhan3\OneDrive\桌面\大二專題\DeepMoon-master';
outputfolder='C:\Users\jhan3\OneDrive\桌面\大二專題\asliceofmoon';

filename='LunarLROLrocKaguya_118mperpix.png';
totalimage=imread(filename);

if size(totalimage,3)>1
    totalimage=rgb2gray(totalimage);
end

tileSize=256;
overlap=32;
step = tileSize - overlap;
[height,width]=size(totalimage);

outputfolder='asliceofmoon';
if ~exist(outputfolder,'dir')
    mkdir(outputfolder);
end

fprintf('開始，%d x %d\n',height,width);
number=0;

tileInfo = [];

for y=1:step:(height-tileSize+1)
    for x=1:step:(width-tileSize+1)

        rect=[x,y,tileSize-1,tileSize-1];
        tile=imcrop(totalimage,rect);

        tile=im2single(tile);
        tile=rescale(tile);

        fname = sprintf('tile_%04d.png', number);
        savename = fullfile(outputfolder, fname);
        imwrite(tile, savename);

        tileInfo = [tileInfo; number, x, y];

        number = number + 1;
    end
end

T = array2table(tileInfo, 'VariableNames', {'tile_id','x_start','y_start'});
writetable(T, fullfile(outputfolder, 'tile_positions.csv'));

fprintf('共生成 %d 張 %d x %d 圖片\n', number, tileSize, tileSize);
